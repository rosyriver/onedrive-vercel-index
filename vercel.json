{
    "github": {
        "silent": true
    },
    "buildCommand": "pnpm build",
    "installCommand": "pnpm install",
    "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':!*.md'",
    "crons": [
        {
            "path": "/api/refresh-auth",
            "schedule": "0 0 * * *"
        }
    ]
}
